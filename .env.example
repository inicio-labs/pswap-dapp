# Copy to `.env.local` and fill in.

# Miden node the dApp reads from (to list balances + build requests).
# devnet | testnet | localhost | custom RPC URL
VITE_RPC_URL=devnet

# ── PRICE SOURCE ──────────────────────────────────────────────────────────
# Base URL of the Miden faucet price API (keyed by faucet id, returns USD price
# + ticker + decimals). Defaults to the live endpoint below if unset.
#   GET {BASE}/v1/prices?ids=<hexFaucetId1>,<hexFaucetId2>
VITE_PRICE_API_URL=https://35-175-40-181.sslip.io

# ── SUPPORTED ASSETS ──────────────────────────────────────────────────────
# The price API has no discovery endpoint, so the selectable asset universe is
# configured here as a comma-separated list of HEX faucet ids. The connected
# wallet's own priced holdings are unioned in at runtime. Defaults to IBTC.
VITE_SUPPORTED_FAUCETS=0xb3722d97036169910fc0eeaccce29b
